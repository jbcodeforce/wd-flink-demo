# Confluent Cloud Kafka (cluster API key)
KAFKA_BOOTSTRAP_SERVERS=pkc-xxxx.region.provider.confluent.cloud:9092
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Schema Registry (dedicated SR API key recommended)
SCHEMA_REGISTRY_URL=https://psrc-xxxx.region.provider.confluent.cloud
SCHEMA_REGISTRY_BASIC_AUTH_USER_INFO=key:secret

# Optional overrides
KAFKA_TOPIC=fct_nb_act_per_pgm
KAFKA_GROUP_ID=wd-fct-nb-act-dashboard
KAFKA_AUTO_OFFSET_RESET=earliest
